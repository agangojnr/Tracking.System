<?xml version="1.1" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.4.xsd">

    <changeSet id="add-uniqueidentifier-filtered-index-to-tc-simcards" author="walter">

        <addColumn tableName="tc_simcards">
            <column name="uniqueidentifier" type="varchar(20)"/>
        </addColumn>
        <sql>
            CREATE UNIQUE INDEX uk_tc_simcards_uniqueidentifier
            ON tc_simcards (uniqueidentifier)
            WHERE uniqueidentifier IS NOT NULL;
        </sql>
    </changeSet>

</databaseChangeLog>

