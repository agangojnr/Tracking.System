<?xml version="1.1" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.4.xsd">

  <changeSet id="create-tc-yards-table" author="walter">

    <createTable tableName="tc_yards">

      <column name="id" type="BIGINT" autoIncrement="true">
        <constraints primaryKey="true"
                     primaryKeyName="pk_tc_yards"
                     nullable="false"/>
      </column>

      <column name="yardname" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>

      <column name="location" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>

    </createTable>

  </changeSet>


  <changeSet id="create-tc-repossessions-table" author="walter">

    <createTable tableName="tc_repossessions">

      <column name="id" type="BIGINT" autoIncrement="true">
        <constraints primaryKey="true"
                     primaryKeyName="pk_tc_repossessions"
                     nullable="false"/>
      </column>

      <column name="auctioneerid" type="BIGINT">
        <constraints nullable="false"/>
      </column>

      <column name="deviceid" type="INT">
        <constraints nullable="false"/>
      </column>

      <column name="yardid" type="BIGINT">
        <constraints nullable="false"/>
      </column>

      <column name="comment" type="VARCHAR(500)"/>

    </createTable>

  </changeSet>

  <changeSet id="fk-tc-repossessions" author="walter">

    <!-- FK: device -->
    <addForeignKeyConstraint
            baseTableName="tc_repossessions"
            baseColumnNames="deviceid"
            referencedTableName="tc_devices"
            referencedColumnNames="id"
            constraintName="fk_repossession_device"
            onDelete="CASCADE"/>

    <!-- FK: yard -->
    <addForeignKeyConstraint
            baseTableName="tc_repossessions"
            baseColumnNames="yardid"
            referencedTableName="tc_yards"
            referencedColumnNames="id"
            constraintName="fk_repossession_yard"
            onDelete="RESTRICT"/>

  </changeSet>

  <changeSet id="modify-auctioneerid-to-int" author="walter">

    <preConditions onFail="HALT">
      <tableExists tableName="tc_repossessions"/>
      <columnExists tableName="tc_repossessions" columnName="auctioneerid"/>
    </preConditions>

    <!-- Change column type -->
    <modifyDataType
            tableName="tc_repossessions"
            columnName="auctioneerid"
            newDataType="INT"/>

  </changeSet>


  <changeSet id="fk-repossession-auctioneer" author="walter">

    <!-- Foreign Key: auctioneer (parent) -> repossession (child) -->
    <addForeignKeyConstraint
            baseTableName="tc_repossessions"
            baseColumnNames="auctioneerid"
            referencedTableName="tc_auctioneers"
            referencedColumnNames="id"
            constraintName="fk_repossession_auctioneer"
            onDelete="RESTRICT"/>

  </changeSet>

  <changeSet id="rename-location-to-yardlocation" author="walter">

    <preConditions onFail="HALT">
      <tableExists tableName="tc_yards"/>
      <columnExists tableName="tc_yards" columnName="location"/>
    </preConditions>

    <!-- Rename column -->
    <renameColumn
            tableName="tc_yards"
            oldColumnName="location"
            newColumnName="yardlocation"
            columnDataType="VARCHAR(255)"/>

  </changeSet>



</databaseChangeLog>

