<?xml version="1.1" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.4.xsd">

  <changeSet id="create-tc-yards-table" author="walter">

    <createTable tableName="tc_yards">

      <column name="id" type="BIGINT" autoIncrement="true">
        <constraints primaryKey="true"
                     primaryKeyName="pk_tc_yards"
                     nullable="false"/>
      </column>

      <column name="yardname" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>

      <column name="yardlocation" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>

    </createTable>

  </changeSet>


  <changeSet id="create-tc-repossessions-table" author="walter">

    <createTable tableName="tc_repossessions">
      <column name="id" type="BIGINT" autoIncrement="true">
        <constraints primaryKey="true"
                     primaryKeyName="pk_tc_repossessions"
                     nullable="false"/>
      </column>

      <column name="auctioneerid" type="INT">
        <constraints nullable="false"/>
      </column>

      <column name="assetid" type="INT">
        <constraints nullable="false"/>
      </column>

      <column name="yardid" type="BIGINT">
        <constraints nullable="false"/>
      </column>

      <column name="comment" type="VARCHAR(500)"/>

    </createTable>

  </changeSet>

  <changeSet id="fk-tc-repossessions" author="walter">

    <!-- FK: device -->
    <addForeignKeyConstraint
            baseTableName="tc_repossessions"
            baseColumnNames="assetid"
            referencedTableName="tc_assets"
            referencedColumnNames="id"
            constraintName="fk_repossession_asset"
            onDelete="CASCADE"/>

    <!-- FK: yard -->
    <addForeignKeyConstraint
            baseTableName="tc_repossessions"
            baseColumnNames="yardid"
            referencedTableName="tc_yards"
            referencedColumnNames="id"
            constraintName="fk_repossession_yard"
            onDelete="RESTRICT"/>

  </changeSet>


  <changeSet id="fk-repossession-auctioneer" author="walter">

    <!-- Foreign Key: auctioneer (parent) -> repossession (child) -->
    <addForeignKeyConstraint
            baseTableName="tc_repossessions"
            baseColumnNames="auctioneerid"
            referencedTableName="tc_auctioneers"
            referencedColumnNames="id"
            constraintName="fk_repossession_auctioneer"
            onDelete="RESTRICT"/>

  </changeSet>

</databaseChangeLog>

