<?xml version="1.1" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.4.xsd">

  <!-- Create tc_subreseller table -->
  <changeSet id="1" author="Walter">
    <createTable tableName="tc_subresellers">
      <column name="id" type="BIGINT" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="subresellername" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="attributes" type="VARCHAR(4000)">
        <constraints nullable="false"/>
      </column>
    </createTable>
  </changeSet>


  <changeSet id="4" author="Walter">
    <createTable tableName="tc_reseller_subreseller">
      <column name="resellerid" type="BIGINT">
        <constraints nullable="false"/>
      </column>
      <column name="subresellerid" type="BIGINT">
        <constraints nullable="false"/>
      </column>
    </createTable>

    <addForeignKeyConstraint
            baseTableName="tc_reseller_subreseller"
            baseColumnNames="resellerid"
            referencedTableName="tc_resellers"
            referencedColumnNames="id"
            constraintName="fk_reseller_subreseller_reseller"/>

    <addForeignKeyConstraint
            baseTableName="tc_reseller_subreseller"
            baseColumnNames="subresellerid"
            referencedTableName="tc_subresellers"
            referencedColumnNames="id"
            constraintName="fk_reseller_subreseller_subreseller"/>
  </changeSet>

</databaseChangeLog>

