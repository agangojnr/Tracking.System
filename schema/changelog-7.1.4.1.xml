<?xml version="1.1" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.4.xsd">

  <!-- Create tc_asset_device only if it does not exist -->

  <changeSet id="create-tc-asset-device-new" author="walter">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="tc_asset_device"/>
      </not>
    </preConditions>

    <createTable tableName="tc_asset_device">
      <column name="deviceid" type="INT">
        <constraints nullable="false"/>
      </column>
      <column name="assetid" type="INT">
        <constraints nullable="false"/>
      </column>
    </createTable>

    <addForeignKeyConstraint baseTableName="tc_asset_device"
                             baseColumnNames="deviceid"
                             constraintName="fk_asset_device_device"
                             referencedTableName="tc_devices"
                             referencedColumnNames="id"
                             onDelete="CASCADE"/>

    <addForeignKeyConstraint baseTableName="tc_asset_device"
                             baseColumnNames="assetid"
                             constraintName="fk_asset_device_asset"
                             referencedTableName="tc_assets"
                             referencedColumnNames="id"
                             onDelete="CASCADE"/>
  </changeSet>

  <!-- Add defaultclientid only if it does not exist -->

  <changeSet id="add-defaultclientid-fk-to-tc_users" author="walter">
    <preConditions onFail="MARK_RAN">
      <not>
        <columnExists tableName="tc_users" columnName="defaultclientid"/>
      </not>
    </preConditions>

    <addColumn tableName="tc_users">
      <column name="defaultclientid" type="BIGINT"/>
    </addColumn>

    <addForeignKeyConstraint
            baseTableName="tc_users"
            baseColumnNames="defaultclientid"
            referencedTableName="tc_clients"
            referencedColumnNames="id"
            constraintName="fk_users_defaultclientid"/>
  </changeSet>

</databaseChangeLog>