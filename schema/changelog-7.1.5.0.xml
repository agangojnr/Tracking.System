<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.4.xsd">

    <changeSet id="add-clientContact-to-tc_assets" author="walter">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="tc_assets" columnName="clientContact"/>
            </not>
        </preConditions>
        <addColumn tableName="tc_assets">
            <column name="clientContact" type="VARCHAR(10)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="add-assetModel-to-tc_assets" author="walter">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="tc_assets" columnName="assetModel"/>
            </not>
        </preConditions>
        <addColumn tableName="tc_assets">
            <column name="assetModel" type="VARCHAR(100)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>