<?xml version="1.1" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.4.xsd">


  <!-- ============================ -->
  <!-- 1. NETWORK PROVIDER STRUCTURE -->
  <!-- ============================ -->

  <changeSet id="1" author="Walter">
    <createTable tableName="tc_networkproviders">
      <column name="id" type="INT" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="name" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="attributes" type="VARCHAR(4000)">
        <constraints nullable="false"/>
      </column>
    </createTable>
  </changeSet>

  <!-- ===================== -->
  <!-- 2. SIMCARD STRUCTURES -->
  <!-- ===================== -->

    <changeSet id="2" author="Walter">
      <createTable tableName="tc_simcards">
        <column name="id" type="INT" autoIncrement="true">
          <constraints primaryKey="true" nullable="false"/>
        </column>
        <column name="phonenumber" type="VARCHAR(255)">
          <constraints nullable="false"/>
        </column>
        <column name="iccid" type="VARCHAR(255)">
          <constraints nullable="false"/>
        </column>
        <column name="attributes" type="VARCHAR(4000)">
          <constraints nullable="false"/>
        </column>
      </createTable>
    </changeSet>
  <!-- ========================= -->
  <!-- 3. ADD FOREIGN KEY COLUMN -->
  <!-- ========================= -->

  <changeSet id="add-networkproviderid-to-simcards" author="Walter">
    <addColumn tableName="tc_simcards">
      <column name="networkproviderid" type="INT"/>
    </addColumn>

    <addForeignKeyConstraint baseTableName="tc_simcards"
                             baseColumnNames="networkproviderid"
                             constraintName="fk_simcard_networkprovider"
                             referencedTableName="tc_networkproviders"
                             referencedColumnNames="id"
                             onDelete="CASCADE"/>
  </changeSet>


  <changeSet id="create-tc-device-simcard" author="walter">
    <createTable tableName="tc_device_simcard">
      <column name="deviceid" type="INT">
        <constraints nullable="false"/>
      </column>
      <column name="simcardid" type="INT">
        <constraints nullable="false"/>
      </column>
    </createTable>

    <addForeignKeyConstraint baseTableName="tc_device_simcard"
                             baseColumnNames="deviceid"
                             constraintName="fk_device_simcard_device"
                             referencedTableName="tc_devices"
                             referencedColumnNames="id"
                             onDelete="CASCADE"/>

    <addForeignKeyConstraint baseTableName="tc_device_simcard"
                             baseColumnNames="simcardid"
                             constraintName="fk_device_simcard_simcard"
                             referencedTableName="tc_simcards"
                             referencedColumnNames="id"
                             onDelete="CASCADE"/>
  </changeSet>

  <!-- ========================= -->
  <!-- 5. EXTRA RELATIONSHIPS -->
  <!-- ========================= -->

  <changeSet id="create-tc-reseller-simcard" author="walter">
    <createTable tableName="tc_reseller_simcard">
      <column name="resellerid" type="BIGINT">
        <constraints nullable="false"/>
      </column>
      <column name="simcardid" type="INT">
        <constraints nullable="false"/>
      </column>
    </createTable>

    <addForeignKeyConstraint baseTableName="tc_reseller_simcard"
                             baseColumnNames="resellerid"
                             constraintName="fk_reseller_simcard_reseller"
                             referencedTableName="tc_resellers"
                             referencedColumnNames="id"
                             onDelete="CASCADE"/>

    <addForeignKeyConstraint baseTableName="tc_reseller_simcard"
                             baseColumnNames="simcardid"
                             constraintName="fk_reseller_simcard_simcard"
                             referencedTableName="tc_simcards"
                             referencedColumnNames="id"
                             onDelete="CASCADE"/>
  </changeSet>

</databaseChangeLog>
