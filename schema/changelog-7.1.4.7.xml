<?xml version="1.1" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.4.xsd">

  <changeSet id="rename-tc-device-asset-table" author="walter">

    <renameTable
            oldTableName="tc_device_asset"
            newTableName="tc_asset_device"/>

  </changeSet>

  <changeSet id="fix-column-order-tc-asset-device" author="walter">

    <createTable tableName="tc_asset_device_new">
      <column name="assetid" type="BIGINT"/>
      <column name="deviceid" type="BIGINT"/>
    </createTable>

    <sql>
      INSERT INTO tc_asset_device_new(deviceid, assetid)
      SELECT deviceid, assetid FROM tc_asset_device;
    </sql>

    <dropTable tableName="tc_asset_device"/>

    <renameTable
            oldTableName="tc_asset_device_new"
            newTableName="tc_asset_device"/>

  </changeSet>



  <changeSet id="rename-auctioneer-device-to-asset" author="walter">

    <!-- Rename table -->
    <renameTable
            oldTableName="tc_auctioneer_device"
            newTableName="tc_auctioneer_asset"/>

    <!-- Rename column -->
    <renameColumn
            tableName="tc_auctioneer_asset"
            oldColumnName="deviceid"
            newColumnName="assetid"
            columnDataType="BIGINT"/>

    <!-- Drop old FK -->
<!--    <dropForeignKeyConstraint-->
<!--            baseTableName="tc_auctioneer_asset"-->
<!--            constraintName="fk_auctioneer_device_device"/>-->

    <!-- Add new FK -->
    <addForeignKeyConstraint
            baseTableName="tc_auctioneer_asset"
            baseColumnNames="assetid"
            referencedTableName="tc_assets"
            referencedColumnNames="id"
            constraintName="fk_auctioneer_asset_asset"
            onDelete="CASCADE"/>
  </changeSet>


  <changeSet id="rename-deviceid-to-assetid-tc-repossessions" author="walter">
    <!-- Rename column -->
    <renameColumn
            tableName="tc_repossessions"
            oldColumnName="deviceid"
            newColumnName="assetid"
            columnDataType="BIGINT"/>

    <rollback>
      <renameColumn
              tableName="tc_repossessions"
              oldColumnName="assetid"
              newColumnName="deviceid"
              columnDataType="BIGINT"/>
    </rollback>

  </changeSet>

  <changeSet id="update-auctioneer-asset-fk-to-assets" author="walter">

    <!-- ============================= -->
