<?xml version="1.1" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.4.xsd">

  <!-- Create tc_simcards table -->
  <changeSet id="1" author="Walter">
    <createTable tableName="tc_devicetypes">
      <column name="id" type="INT" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="model" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="manufacturer" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="class" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="attributes" type="VARCHAR(4000)">
        <constraints nullable="false"/>
      </column>
    </createTable>
  </changeSet>

  <changeSet id="rename-class-to-deviceclass" author="Walter">
    <renameColumn
            tableName="tc_devicetypes"
            oldColumnName="class"
            newColumnName="deviceclass"
            columnDataType="VARCHAR(255)"/>
  </changeSet>


  <changeSet id="add-devicetypeid-to-devices" author="Walter">
    <addColumn tableName="tc_devices">
      <column name="devicetypeid" type="INT">
        <constraints nullable="false" foreignKeyName="fk_device_devicetype"
                     referencedTableName="tc_devicetypes"
                     referencedColumnNames="id"/>
      </column>
    </addColumn>
  </changeSet>

    <changeSet id="rename-model-to-oldmodelname-tc-devices" author="walter">

      <preConditions onFail="MARK_RAN">
        <and>
          <tableExists tableName="tc_devices"/>
          <columnExists tableName="tc_devices" columnName="model"/>
          <not>
            <columnExists tableName="tc_devices" columnName="oldmodelname"/>
          </not>
        </and>
      </preConditions>

      <renameColumn
              tableName="tc_devices"
              oldColumnName="model"
              newColumnName="oldmodelname"
              columnDataType="VARCHAR(128)"/>

    </changeSet>

    <changeSet id="swap-deviceid-assetid-columns-tc_asset_device" author="walter">

      <!-- Ensure table exists -->
      <preConditions onFail="MARK_RAN">
        <tableExists tableName="tc_asset_device"/>
      </preConditions>

      <!-- Step 1: Rename existing columns temporarily -->
      <renameColumn
              tableName="tc_asset_device"
              oldColumnName="deviceid"
              newColumnName="temp_deviceid"
              columnDataType="INT"/>

      <renameColumn
              tableName="tc_asset_device"
              oldColumnName="assetid"
              newColumnName="deviceid"
              columnDataType="INT"/>

      <!-- Step 2: Rename temp column to assetid -->
      <renameColumn
              tableName="tc_asset_device"
              oldColumnName="temp_deviceid"
              newColumnName="assetid"
              columnDataType="INT"/>

    </changeSet>


    <changeSet id="swap-columns-and-recreate-fk-tc_asset_device" author="walter">

      <!-- Ensure table exists -->
      <preConditions onFail="MARK_RAN">
        <tableExists tableName="tc_asset_device"/>
      </preConditions>

      <!-- Drop old foreign keys -->
      <dropForeignKeyConstraint
              baseTableName="tc_asset_device"
              constraintName="fk_asset_device_device"/>

      <dropForeignKeyConstraint
              baseTableName="tc_asset_device"
              constraintName="fk_asset_device_asset"/>

      <!-- Recreate FK for new assetid column -->
      <addForeignKeyConstraint
              baseTableName="tc_asset_device"
              baseColumnNames="assetid"
              constraintName="fk_asset_device_asset_new"
              referencedTableName="tc_assets"
              referencedColumnNames="id"
              onDelete="CASCADE"/>

      <!-- Recreate FK for new deviceid column -->
      <addForeignKeyConstraint
              baseTableName="tc_asset_device"
              baseColumnNames="deviceid"
              constraintName="fk_asset_device_device_new"
              referencedTableName="tc_devices"
              referencedColumnNames="id"
              onDelete="CASCADE"/>

    </changeSet>

</databaseChangeLog>

