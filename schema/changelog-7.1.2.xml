<?xml version="1.1" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.4.xsd">

  <!-- Create tc_client table -->
  <changeSet id="1" author="Walter">
    <createTable tableName="tc_clients">
      <column name="id" type="BIGINT" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="clientname" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="attributes" type="VARCHAR(4000)">
        <constraints nullable="false"/>
      </column>
    </createTable>
  </changeSet>


  <changeSet id="4" author="Walter">
    <createTable tableName="tc_subreseller_client">
      <column name="subresellerid" type="BIGINT">
        <constraints nullable="false"/>
      </column>
      <column name="clientid" type="BIGINT">
        <constraints nullable="false"/>
      </column>
    </createTable>

    <addForeignKeyConstraint
            baseTableName="tc_subreseller_client"
            baseColumnNames="subresellerid"
            referencedTableName="tc_subresellers"
            referencedColumnNames="id"
            constraintName="fk_subreseller_client_subreseller"/>

    <addForeignKeyConstraint
            baseTableName="tc_subreseller_client"
            baseColumnNames="clientid"
            referencedTableName="tc_clients"
            referencedColumnNames="id"
            constraintName="fk_subreseller_client_client"/>
  </changeSet>

</databaseChangeLog>

